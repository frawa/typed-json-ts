{
  "name": "typed-json-ts",
  "version": "0.1.0",
  "description": "Typescript bindings for typed-json.",
  "author": {
    "name": "Frank Wagner",
    "email": "agilecoderfrank@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/frawa/typed-json-ts"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist",
    "build:wasm": "ucm transcript build-wasm.md",
    "build:wasm:local": "ucm transcript.fork build-wasm-local.md",
    "copy:wasm": "cp ./src/wasm/*.wasm ./dist",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run copy:wasm && npm run build:ts",
    "watch": "tsc -w",
    "test": "vitest",
    "ci": "npm run clean && npm run build && npm run test"
  },
  "engines": {
    "node": ">=22.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
